{
    "version": "2.0.0",
    "inputs": [
        {
            "id": "selectBoard",
            "type": "pickString",
            "description": "选择开发板",
            "options": [
                "damiao_h7",
                "dji_c"
            ],
            "default": "dji_c"
        },
        {
            "id": "selectProbe",
            "type": "pickString",
            "description": "选择调试器",
            "options": [
                "stlink",
                "daplink",
                "jlink"
            ],
            "default": "jlink"
        }
    ],
    "tasks": [
        {
            "label": "Build damiao_h7",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "group": "test",
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "echo": true,
                "showReuseMessage": false
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "cmake -S ${workspaceFolder}/board/damiao_h7 -B ${workspaceFolder}/build/damiao_h7/Debug --preset Debug -G Ninja; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; cmake --build ${workspaceFolder}/build/damiao_h7/Debug --config Debug -j ${env:NUMBER_OF_PROCESSORS}; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; Copy-Item -Path ${workspaceFolder}/build/damiao_h7/Debug/compile_commands.json -Destination ${workspaceFolder}/build/compile_commands.json -Force; Copy-Item -Path ${workspaceFolder}/build/damiao_h7/Debug/base.elf -Destination ${workspaceFolder}/build/damiao_h7.elf -Force"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-lc",
                    "cmake -S ${workspaceFolder}/board/damiao_h7 -B ${workspaceFolder}/build/damiao_h7/Debug --preset Debug -G Ninja && cmake --build ${workspaceFolder}/build/damiao_h7/Debug --config Debug -j $(nproc) && cp ${workspaceFolder}/build/damiao_h7/Debug/compile_commands.json ${workspaceFolder}/build/compile_commands.json && cp ${workspaceFolder}/build/damiao_h7/Debug/base.elf ${workspaceFolder}/build/damiao_h7.elf"
                ]
            }
        },
        {
            "label": "Build dji_c",
            "type": "shell",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "echo": true,
                "showReuseMessage": false
            },
            "windows": {
                "command": "powershell",
                "args": [
                    "-Command",
                    "cmake -S ${workspaceFolder}/board/dji_c -B ${workspaceFolder}/build/dji_c/Debug --preset Debug -G Ninja; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; cmake --build ${workspaceFolder}/build/dji_c/Debug --config Debug -j ${env:NUMBER_OF_PROCESSORS}; if ($LASTEXITCODE -ne 0) { exit $LASTEXITCODE }; Copy-Item -Path ${workspaceFolder}/build/dji_c/Debug/compile_commands.json -Destination ${workspaceFolder}/build/compile_commands.json -Force; Copy-Item -Path ${workspaceFolder}/build/dji_c/Debug/base.elf -Destination ${workspaceFolder}/build/dji_c.elf -Force"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-lc",
                    "cmake -S ${workspaceFolder}/board/dji_c -B ${workspaceFolder}/build/dji_c/Debug --preset Debug -G Ninja && cmake --build ${workspaceFolder}/build/dji_c/Debug --config Debug -j $(nproc) && cp ${workspaceFolder}/build/dji_c/Debug/compile_commands.json ${workspaceFolder}/build/compile_commands.json && cp ${workspaceFolder}/build/dji_c/Debug/base.elf ${workspaceFolder}/build/dji_c.elf"
                ]
            },
            "group": {
                "kind": "test",
                "isDefault": true
            }
        },
        {
            "label": "Flash board",
            "type": "shell",
            "problemMatcher": [],
            "presentation": {
                "reveal": "always",
                "panel": "shared",
                "focus": false,
                "echo": true,
                "showReuseMessage": false,
                "close": true
            },
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "windows": {
                "command": "cmd",
                "args": [
                    "/c",
                    "${workspaceFolder}/.vscode/flash_interactive.bat ${input:selectBoard} ${input:selectProbe}"
                ]
            },
            "linux": {
                "command": "bash",
                "args": [
                    "-c",
                    "${workspaceFolder}/.vscode/flash_interactive.sh ${input:selectBoard} ${input:selectProbe}"
                ]
            }
        }
    ]
}